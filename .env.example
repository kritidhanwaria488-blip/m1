# Mutual Fund FAQ Assistant - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# API Configuration (Phase 6/9)
# ============================================
# Groq API Key for LLM generation
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: Override default model
# GROQ_MODEL=llama-3.1-8b-instant

# ============================================
# Admin Configuration (Phase 9)
# ============================================
# Secret token for admin reindex endpoint
ADMIN_REINDEX_SECRET=your_secure_random_string_here

# ============================================
# API Server (Phase 9)
# ============================================
PORT=8000
API_HOST=0.0.0.0

# Debug mode: 1 = include debug info in responses, 0 = production mode
RUNTIME_API_DEBUG=1

# ============================================
# Vector Store (Phase 4.3 - Local ChromaDB)
# ============================================
# Local ChromaDB storage directory
CHROMA_PERSIST_DIR=data/chroma

# Collection name for vector store
INGEST_CHROMA_COLLECTION=mf_faq_chunks

# ============================================
# Ingestion Configuration (Phase 4)
# ============================================
# Directory for raw scraped HTML
INGEST_RAW_DIR=data/raw

# Directory for structured extracted data
INGEST_STRUCTURED_DIR=data/structured

# User agent for scraping (identifies your bot)
INGEST_USER_AGENT="MutualFundFAQ-Assistant/1.0 (contact@example.com)"

# Request timeout for scraping (seconds)
INGEST_TIMEOUT=30

# Rate limit: seconds between requests
INGEST_RATE_LIMIT=2

# ============================================
# Thread Storage (Phase 8)
# ============================================
# SQLite database path (dev)
THREAD_DB_PATH=data/threads.db

# Max turns to keep in context window
THREAD_MAX_TURNS=6

# Production: Postgres connection string (optional)
# DATABASE_URL=postgresql://user:pass@localhost/mf_faq

# ============================================
# UI Configuration (Phase 11)
# ============================================
# Next.js dev server port
# NEXT_PORT=3000

# API URL for UI to connect to
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Embedding Model (Phase 4.2)
# ============================================
# Frozen at BAAI/bge-small-en-v1.5 for reproducibility
# Do not change without reindexing entire corpus
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
EMBEDDING_MAX_TOKENS=512
